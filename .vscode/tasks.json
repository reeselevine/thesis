      "type": "shell",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-pvc",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "main.tex"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
